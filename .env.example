# CursorBeam Configuration Template
# Copy this file to .env and fill in your values
# Or run: npm run setup (recommended - GUI installer!)

# ============================================
# REQUIRED: Authentication Password
# ============================================
# Password for logging into the PWA from your phone
# Generate a secure random password (16+ characters recommended)
PASSWORD=your-secure-password-here

# ============================================
# REQUIRED: Cursor Executable Path
# ============================================
# Full path to Cursor executable on your system
# Windows: C:\Users\YourName\AppData\Local\Programs\cursor\Cursor.exe
# macOS: /Applications/Cursor.app/Contents/MacOS/Cursor
# Linux: /usr/bin/cursor
# The setup script will auto-detect this for you
CURSOR_EXE=C:\Users\YourName\AppData\Local\Programs\cursor\Cursor.exe

# ============================================
# OPTIONAL: Ports
# ============================================
# Port for the relay server (default: 9800)
PORT=9800

# Chrome DevTools Protocol port (default: 9222)
CDP_PORT=9222

# ============================================
# OPTIONAL: Project Management
# ============================================
# Root directory containing your projects
# If set, the PWA will show a project picker
# Leave commented to disable project switching
# PROJECTS_ROOT=C:\Users\YourName\projects

# ============================================
# OPTIONAL: Performance Tuning
# ============================================
# Polling interval in milliseconds (default: 1500)
# Lower = more responsive, higher = less CPU usage
# POLL_MS=1500

# ============================================
# ADVANCED: Network Binding
# ============================================
# Internal setting - bind address for the server
# Default: 127.0.0.1 (local only)
# Use 0.0.0.0 to allow external connections
# BIND_ADDR=127.0.0.1
