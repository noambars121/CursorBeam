{
  "name": "cursor-mobile-bridge",
  "displayName": "Cursor Mobile Bridge",
  "description": "Bridge between Cursor IDE and Cursor Mobile app on iPhone",
  "version": "1.0.0",
  "publisher": "cursor-mobile",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "cursor-mobile.start",
        "title": "Cursor Mobile: Start Bridge Server"
      },
      {
        "command": "cursor-mobile.stop",
        "title": "Cursor Mobile: Stop Bridge Server"
      },
      {
        "command": "cursor-mobile.status",
        "title": "Cursor Mobile: Show Status"
      }
    ],
    "configuration": {
      "title": "Cursor Mobile Bridge",
      "properties": {
        "cursorMobile.port": {
          "type": "number",
          "default": 8766,
          "description": "Port for the bridge server (must be different from main server)"
        },
        "cursorMobile.autoStart": {
          "type": "boolean",
          "default": true,
          "description": "Automatically start bridge server when Cursor opens"
        },
        "cursorMobile.apiKey": {
          "type": "string",
          "default": "changeme",
          "description": "API key for authentication (must match mobile app)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.80.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "typescript": "^5.0.0",
    "@vscode/vsce": "^2.19.0"
  },
  "dependencies": {}
}

