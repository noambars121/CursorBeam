{
  "name": "cursorbeam",
  "version": "1.1.0",
  "description": "Remote control Cursor IDE from mobile devices - Secure PWA with voice input (Whisper AI), push notifications, WebSocket sync, terminal access, and Tailscale support for anywhere access",
  "main": "src/start.ts",
  "type": "module",
  "scripts": {
    "setup": "powershell -ExecutionPolicy Bypass -File setup.ps1",
    "installer": "powershell -ExecutionPolicy Bypass -File install.ps1",
    "build:installer": "powershell -ExecutionPolicy Bypass -File installer/build-installer.ps1",
    "start": "npx tsx src/start.ts",
    "relay": "npx tsx src/relay-server.ts",
    "check": "tsc --noEmit",
    "test:edit": "npx tsx src/edit-flow.test.ts",
    "service:install": "node service-install.cjs",
    "service:uninstall": "node service-uninstall.cjs",
    "service:start": "node service-control.cjs start",
    "service:stop": "node service-control.cjs stop",
    "service:restart": "node service-control.cjs restart"
  },
  "keywords": [
    "cursor",
    "cursor-ide",
    "cursor-remote",
    "cursor-mobile",
    "cursor-control",
    "ide-remote-control",
    "mobile-development",
    "pwa",
    "progressive-web-app",
    "remote-control",
    "remote-development",
    "mobile-ide",
    "tailscale",
    "vpn",
    "websocket",
    "realtime",
    "chrome-devtools-protocol",
    "cdp",
    "typescript",
    "nodejs",
    "express",
    "react",
    "mobile-first",
    "developer-tools",
    "productivity",
    "workflow",
    "automation",
    "ai-assistant",
    "code-editor",
    "terminal-access",
    "ssh-alternative"
  ],
  "author": "Noam Barsheshet <noambars121@gmail.com> (https://www.barsbuild.me)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/noambars121/CursorBeam.git"
  },
  "bugs": {
    "url": "https://github.com/noambars121/CursorBeam/issues"
  },
  "homepage": "https://github.com/noambars121/CursorBeam#readme",
  "dependencies": {
    "@types/ws": "^8.18.1",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "fast-glob": "^3.3.2",
    "helmet": "^7.1.0",
    "js-yaml": "^4.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "node-windows": "^1.0.0-beta.8",
    "pino": "^8.17.2",
    "pino-pretty": "^10.3.1",
    "web-push": "^3.6.7",
    "ws": "^8.18.3",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/js-yaml": "^4.0.9",
    "@types/jsdom": "^28.0.1",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.10.6",
    "@types/web-push": "^3.6.4",
    "jsdom": "^29.0.2",
    "nodemon": "^3.0.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "ts-node": {
    "esm": true,
    "experimentalSpecifierResolution": "node"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
